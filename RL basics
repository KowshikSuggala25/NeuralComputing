# Exploration vs Exploitation using Epsilon-Greedy
# ==============================================

import numpy as np
import random
import matplotlib.pyplot as plt


# ------------------------------------------------
# Epsilon-Greedy Action Selection Function
# ------------------------------------------------

def epsilon_greedy(Q, state, epsilon):

    n_actions = Q.shape[1]

    if random.random() < epsilon:
        action = random.randrange(n_actions)
        decision = "Exploration (random)"
    else:
        action = int(np.argmax(Q[state]))
        decision = "Exploitation (greedy)"

    return action, decision


# ------------------------------------------------
# Dummy Q-table for demonstration
# ------------------------------------------------

Q = np.array([[0.2, 0.5, -0.1, 0.7]])  # 1 state, 4 actions

state = 0


# ------------------------------------------------
# Epsilon Parameters
# ------------------------------------------------

epsilon = 1.0
epsilon_min = 0.05
epsilon_decay = 0.90

episodes = 20


epsilon_history = []


print("Demonstrating Exploration vs Exploitation\n")


# ------------------------------------------------
# Simulation Loop
# ------------------------------------------------

for episode in range(episodes):

    action, decision = epsilon_greedy(Q, state, epsilon)

    epsilon_history.append(epsilon)

    print(f"Episode {episode+1:2d} | epsilon={epsilon:.3f} | action={action} | {decision}")

    # decay epsilon
    epsilon = max(epsilon_min, epsilon * epsilon_decay)


# ------------------------------------------------
# Plot epsilon decay curve
# ------------------------------------------------

plt.figure(figsize=(6,4))

plt.plot(epsilon_history, marker='o')

plt.title("Epsilon Decay: Exploration → Exploitation")

plt.xlabel("Episode")

plt.ylabel("Epsilon")

plt.grid(True)

plt.show()


# ------------------------------------------------
# Show Best Action According to Q-table
# ------------------------------------------------

best_action = np.argmax(Q[state])

print("\nBest action according to Q-table:", best_action)
print("Q-values:", Q[state])
                               
