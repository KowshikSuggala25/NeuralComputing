import numpy as np
import random

# -------------------------------
# Grid World Environment
# -------------------------------

class GridWorld:
    
    def __init__(self, rows=5, cols=5):
        self.rows = rows
        self.cols = cols
        self.n_actions = 4   # up, down, left, right
        
        self.start = (0,0)
        self.goal = (rows-1, cols-1)
        
        self.reset()
        
    def state_to_index(self, state):
        return state[0] * self.cols + state[1]
    
    def reset(self):
        self.agent = self.start
        return self.state_to_index(self.agent)
    
    def step(self, action):
        
        r,c = self.agent
        
        if action == 0:   # up
            r = max(r-1,0)
        elif action == 1: # down
            r = min(r+1,self.rows-1)
        elif action == 2: # left
            c = max(c-1,0)
        elif action == 3: # right
            c = min(c+1,self.cols-1)
        
        self.agent = (r,c)
        
        done = self.agent == self.goal
        
        if done:
            reward = 10
        else:
            reward = -1
        
        return self.state_to_index(self.agent), reward, done


# -------------------------------
# Q-Learning Episode
# -------------------------------

def run_episode(env, Q, alpha, gamma, epsilon_decay):
    
    s = env.reset()
    epsilon = 1.0
    success = 0
    
    for _ in range(200):
        
        # exploration vs exploitation
        if random.random() < epsilon:
            a = random.randrange(env.n_actions)
        else:
            a = int(np.argmax(Q[s]))
        
        s_next, r, done = env.step(a)
        
        best_next = np.max(Q[s_next])
        
        Q[s,a] += alpha * (r + gamma * best_next - Q[s,a])
        
        s = s_next
        
        epsilon = max(0.05, epsilon * epsilon_decay)
        
        if done:
            success = 1
            break
    
    return success


# -------------------------------
# Evaluate Hyperparameters
# -------------------------------

def evaluate_hyperparameters(env, alpha, gamma, epsilon_decay, trials=30):
    
    n_states = env.rows * env.cols
    Q = np.zeros((n_states, env.n_actions))
    
    successes = 0
    
    for _ in range(trials):
        successes += run_episode(env, Q, alpha, gamma, epsilon_decay)
    
    return successes / trials


# -------------------------------
# Create Environment
# -------------------------------

env = GridWorld()


# -------------------------------
# Hyperparameter Search Ranges
# -------------------------------

alpha_range = [0.2, 0.4, 0.6, 0.8]
gamma_range = [0.90, 0.95, 0.98, 0.99]
eps_decay_range = [0.995, 0.997, 0.999]


# -------------------------------
# Random Search
# -------------------------------

results = []

trials = 20   # increase this for better search

for i in range(trials):
    
    alpha = random.choice(alpha_range)
    gamma = random.choice(gamma_range)
    eps_decay = random.choice(eps_decay_range)
    
    score = evaluate_hyperparameters(env, alpha, gamma, eps_decay)
    
    results.append((score, alpha, gamma, eps_decay))
    
    print(f"Test {i+1}: score={score:.3f} | α={alpha}, γ={gamma}, ε_decay={eps_decay}")


# -------------------------------
# Find Best Configuration
# -------------------------------

best = max(results, key=lambda x: x[0])

print("\nBest configuration found:")
print(f"Success rate={best[0]:.3f}")
print(f"alpha={best[1]}")
print(f"gamma={best[2]}")
print(f"epsilon_decay={best[3]}")


