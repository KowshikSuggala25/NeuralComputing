"""
Hyperparameter Impact Analysis for Q-learning in GridWorld
Generates plots and CSV results
"""

import numpy as np
import random
import matplotlib.pyplot as plt
import csv
from statistics import mean, stdev


# ---------------------------------------------------
# GridWorld Environment
# ---------------------------------------------------

class GridWorld:

    def __init__(self, rows=4, cols=4, start=(0,0), goal=(3,3), obstacles=None,
                 step_reward=-0.01, goal_reward=1.0):

        self.rows = rows
        self.cols = cols
        self.start = start
        self.goal = goal
        self.obstacles = set(obstacles) if obstacles else set()
        self.step_reward = step_reward
        self.goal_reward = goal_reward

        self.actions = [(-1,0),(1,0),(0,-1),(0,1)]
        self.n_actions = len(self.actions)


    def state_to_index(self,s):
        return s[0]*self.cols + s[1]


    def reset(self):
        self.agent_pos = self.start
        return self.state_to_index(self.agent_pos)


    def step(self,action_idx):

        move = self.actions[action_idx]
        next_pos = (self.agent_pos[0] + move[0],
                    self.agent_pos[1] + move[1])

        r,c = next_pos

        if r<0 or r>=self.rows or c<0 or c>=self.cols:
            next_pos = self.agent_pos

        if next_pos in self.obstacles:
            next_pos = self.agent_pos

        self.agent_pos = next_pos

        done = self.agent_pos == self.goal
        reward = self.goal_reward if done else self.step_reward

        return self.state_to_index(self.agent_pos), reward, done


# ---------------------------------------------------
# Q Learning Training
# ---------------------------------------------------

def train_q_learning(env, alpha=0.6, gamma=0.98,
                     epsilon_init=1.0, epsilon_min=0.05,
                     epsilon_decay=0.995,
                     episodes=500, max_steps=50, seed=None):

    if seed is not None:
        random.seed(seed)
        np.random.seed(seed)

    n_states = env.rows * env.cols
    Q = np.zeros((n_states, env.n_actions))

    episode_rewards=[]
    episode_steps=[]
    successes=0

    for ep in range(episodes):

        s=env.reset()
        epsilon=epsilon_init
        total_reward=0
        done=False

        for step in range(max_steps):

            if random.random() < epsilon:
                a=random.randrange(env.n_actions)
            else:
                a=int(np.argmax(Q[s]))

            s_next,r,done=env.step(a)

            total_reward+=r

            best_next=np.max(Q[s_next])

            Q[s,a]+=alpha*(r + gamma*best_next - Q[s,a])

            s=s_next

            if done:
                successes+=1
                episode_steps.append(step+1)
                break

        if not done:
            episode_steps.append(max_steps)

        episode_rewards.append(total_reward)

        epsilon_init=max(epsilon_min, epsilon_init*epsilon_decay)

    success_rate=successes/episodes
    avg_reward=mean(episode_rewards)

    if successes>0:
        avg_steps_success=mean([s for s in episode_steps if s<max_steps])
    else:
        avg_steps_success=None

    return {
        "success_rate":success_rate,
        "avg_reward":avg_reward,
        "avg_steps_success":avg_steps_success
    }


# ---------------------------------------------------
# Hyperparameter Sweep
# ---------------------------------------------------

def sweep_param(env,param_name,values,fixed_params,repeats=5):

    results=[]

    for v in values:

        metrics={"success":[], "reward":[], "steps":[]}

        for rep in range(repeats):

            params=fixed_params.copy()

            if param_name=="alpha":
                params["alpha"]=v
            elif param_name=="gamma":
                params["gamma"]=v
            elif param_name=="epsilon_decay":
                params["epsilon_decay"]=v
            elif param_name=="episodes":
                params["episodes"]=v

            out=train_q_learning(env, **params, seed=rep)

            metrics["success"].append(out["success_rate"])
            metrics["reward"].append(out["avg_reward"])

            if out["avg_steps_success"] is not None:
                metrics["steps"].append(out["avg_steps_success"])

        res={
            "value":v,
            "success_mean":mean(metrics["success"]),
            "success_std":stdev(metrics["success"]) if len(metrics["success"])>1 else 0,
            "reward_mean":mean(metrics["reward"]),
            "reward_std":stdev(metrics["reward"]) if len(metrics["reward"])>1 else 0,
            "steps_mean":mean(metrics["steps"]) if metrics["steps"] else None
        }

        results.append(res)

        print(f"{param_name}={v} -> success={res['success_mean']:.3f}")

    return results


# ---------------------------------------------------
# Plot Function
# ---------------------------------------------------

def plot_metric(results,param_name,metric,out_file):

    xs=[r["value"] for r in results]
    ys=[r[f"{metric}_mean"] for r in results]

    plt.figure()
    plt.plot(xs,ys,marker='o')
    plt.xlabel(param_name)
    plt.ylabel(metric)
    plt.title(f"{metric} vs {param_name}")
    plt.grid(True)

    plt.savefig(out_file)
    plt.close()

    print("Saved:",out_file)


