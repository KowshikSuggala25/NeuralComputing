    results.append((mean_acc, std_acc, alpha, gamma, eps_decay))
    
    print(f"α={alpha}, γ={gamma}, decay={eps_decay} → mean={mean_acc:.3f}, std={std_acc:.3f}")


# ----------------------------------------------
