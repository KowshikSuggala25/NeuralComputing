            reward = 10
        else:
            reward = -1
        
        return self.state_to_index(self.agent), reward, done


# ----------------------------------------------
# Train Agent using Q-Learning
# ----------------------------------------------

def train_agent(env, alpha, gamma, eps_decay, episodes=2000):
    
    n_states = env.rows * env.cols
    Q = np.zeros((n_states, env.n_actions))
    
    success_count = 0
    
    for _ in range(episodes):
        
        s = env.reset()
        epsilon = 1.0
        
        for _ in range(50):
            
            if random.random() < epsilon:
                a = random.randrange(env.n_actions)
            else:
                a = int(np.argmax(Q[s]))
            
            s_next, r, done = env.step(a)
            
            best_next = np.max(Q[s_next])
            
            Q[s,a] += alpha * (r + gamma * best_next - Q[s,a])
            
            s = s_next
            
            epsilon = max(0.05, epsilon * eps_decay)
            
            if done:
                success_count += 1
                break
    
    return success_count / episodes


# ----------------------------------------------
# Cross Validation Function
# ----------------------------------------------

def cross_validate(env, alpha, gamma, eps_decay, k=5):
    
    scores = []
    
    for fold in range(k):
        
        # different random seed each fold
        random.seed(fold)
        np.random.seed(fold)
        
        score = train_agent(env, alpha, gamma, eps_decay)
        
        scores.append(score)
    
    return np.mean(scores), np.std(scores)


