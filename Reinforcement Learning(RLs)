# MAIN EXPERIMENT
# ---------------------------------------------------

obstacles={(1,1),(2,1)}

env=GridWorld(4,4,(0,0),(3,3),obstacles)

fixed={
"alpha":0.6,
"gamma":0.98,
"epsilon_init":1.0,
"epsilon_min":0.05,
"epsilon_decay":0.995,
"episodes":500,
"max_steps":50
}


# Sweep Alpha
alpha_vals=[0.1,0.25,0.5,0.75,0.9]
alpha_results=sweep_param(env,"alpha",alpha_vals,fixed)

plot_metric(alpha_results,"alpha","success","success_vs_alpha.png")
plot_metric(alpha_results,"alpha","reward","reward_vs_alpha.png")


# Sweep Gamma
gamma_vals=[0.7,0.85,0.95,0.98,0.995]
gamma_results=sweep_param(env,"gamma",gamma_vals,fixed)

plot_metric(gamma_results,"gamma","success","success_vs_gamma.png")


# Sweep Epsilon Decay
eps_vals=[0.990,0.994,0.996,0.998,0.999]
eps_results=sweep_param(env,"epsilon_decay",eps_vals,fixed)

plot_metric(eps_results,"epsilon_decay","success","success_vs_epsilon_decay.png")


