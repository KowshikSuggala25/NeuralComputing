    def step(self, action):
        
        r, c = self.agent
        
        if action == 0:  # up
            r = max(r-1,0)
        elif action == 1: # down
            r = min(r+1,self.rows-1)
        elif action == 2: # left
            c = max(c-1,0)
        elif action == 3: # right
            c = min(c+1,self.cols-1)
        
        self.agent = (r,c)
        
